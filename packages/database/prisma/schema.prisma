/// Prisma Client 生成器
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

/// 数据源配置：当前阶段使用 MySQL 8.0
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// 用户角色枚举
/// - USER: 普通用户/患者/家属
/// - ESCORT: 陪诊员
enum UserRole {
  USER
  ESCORT
}

/// 订单状态枚举
/// - PENDING_PAYMENT: 待支付
/// - PENDING_ACCEPT: 待接单
/// - IN_SERVICE: 服务中
/// - COMPLETED: 已完成
/// - CANCELLED: 已取消
/// - REFUNDING: 退款中
enum OrderStatus {
  PENDING_PAYMENT
  PENDING_ACCEPT
  IN_SERVICE
  COMPLETED
  CANCELLED
  REFUNDING
}

/// 系统用户表
/// 用于存储普通用户和陪诊员的统一账号信息
model User {
  /// 主键 ID，使用 CUID 便于前后端分布式场景
  id String @id @default(cuid()) @db.VarChar(36)

  /// 手机号，作为核心登录标识之一
  phone String @unique @db.VarChar(20)

  /// 用户昵称
  nickname String? @db.VarChar(50)

  /// 真实姓名
  realName String? @db.VarChar(50)

  /// 用户角色：普通用户或陪诊员
  role UserRole @default(USER)

  /// 账号是否启用
  isActive Boolean @default(true)

  /// 用户创建的订单列表
  createdOrders Order[] @relation("CustomerOrders")

  /// 作为陪诊员承接的订单列表
  acceptedOrders Order[] @relation("EscortOrders")

  /// 陪诊员扩展资料，一对一关系
  escortProfile EscortProfile?

  /// 创建时间
  createdAt DateTime @default(now())

  /// 更新时间
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([isActive])
  @@map("users")
}

/// 陪诊员资料表
/// 仅当用户角色为 ESCORT 时才会存在该记录
model EscortProfile {
  /// 主键 ID
  id String @id @default(cuid()) @db.VarChar(36)

  /// 关联的用户 ID
  userId String @unique @db.VarChar(36)

  /// 身份证号，可用于实名认证
  idCardNo String @unique @db.VarChar(32)

  /// 资格证书编号，可为空
  certificateNo String? @db.VarChar(64)

  /// 擅长领域，例如挂号、取药、住院陪护等
  specialty String? @db.VarChar(255)

  /// 从业年限
  serviceYears Int @default(0)

  /// 个人简介
  bio String? @db.Text

  /// 资质审核是否通过
  isVerified Boolean @default(false)

  /// 创建时间
  createdAt DateTime @default(now())

  /// 更新时间
  updatedAt DateTime @updatedAt

  /// 关联用户
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isVerified])
  @@map("escort_profiles")
}

/// 订单表
/// 描述用户发起的陪诊服务订单
model Order {
  /// 主键 ID
  id String @id @default(cuid()) @db.VarChar(36)

  /// 下单用户 ID
  customerId String @db.VarChar(36)

  /// 接单陪诊员 ID，未接单前允许为空
  escortId String? @db.VarChar(36)

  /// 订单编号，便于外部系统和人工检索
  orderNo String @unique @db.VarChar(32)

  /// 就诊医院名称
  hospitalName String @db.VarChar(100)

  /// 就诊科室名称
  departmentName String? @db.VarChar(100)

  /// 服务日期时间
  serviceAt DateTime

  /// 服务地址或集合地点
  serviceAddress String? @db.VarChar(255)

  /// 用户备注
  remark String? @db.Text

  /// 订单金额，保留两位小数
  amount Decimal @db.Decimal(10, 2)

  /// 当前订单状态
  status OrderStatus @default(PENDING_PAYMENT)

  /// 下单用户
  customer User @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Restrict)

  /// 接单陪诊员
  escort User? @relation("EscortOrders", fields: [escortId], references: [id], onDelete: SetNull)

  /// 创建时间
  createdAt DateTime @default(now())

  /// 更新时间
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([escortId])
  @@index([status])
  @@index([serviceAt])
  @@map("orders")
}

