/// Prisma Client 生成器
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

/// 数据源配置：MySQL 8.0
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// 用户角色
/// - USER: 普通用户
/// - ESCORT: 陪诊员
enum UserRole {
  USER
  ESCORT
  ADMIN
}

enum EscortProfileStatus {
  PENDING
  APPROVED
  REJECTED
}

/// 订单状态
/// - PENDING_PAYMENT: 待支付
/// - PENDING_ACCEPT: 待接单
/// - IN_SERVICE: 服务中
/// - COMPLETED: 已完成
/// - CANCELLED: 已取消
enum OrderStatus {
  PENDING_PAYMENT
  PENDING_ACCEPT
  IN_SERVICE
  COMPLETED
  CANCELLED
}

/// 用户表
model User {
  /// 主键 ID，CUID 字符串
  id String @id @default(cuid()) @db.VarChar(36)

  /// 手机号
  phone String @unique @db.VarChar(20)

  /// 昵称
  nickname String? @db.VarChar(50)

  /// 登录密码哈希，不存储明文密码
  password String @db.VarChar(255)

  /// 用户角色
  role UserRole @default(USER)

  /// 用户创建的订单
  createdOrders Order[] @relation("CustomerOrders")

  /// 陪诊员接单列表
  acceptedOrders Order[] @relation("EscortOrders")

  /// 陪诊员资料
  escortProfile EscortProfile?

  /// 创建时间
  createdAt DateTime @default(now())

  /// 更新时间
  updatedAt DateTime @updatedAt

  @@index([role])
  @@map("users")
}

/// 陪诊员资料表
model EscortProfile {
  /// 主键 ID
  id String @id @default(cuid()) @db.VarChar(36)

  /// 关联用户 ID
  userId String @unique @db.VarChar(36)

  /// 身份证号
  idCardNo String @unique @db.VarChar(32)

  /// 审核通过标志
  isVerified Boolean @default(false)

  status EscortProfileStatus @default(PENDING)

  rejectionReason String? @db.Text

  /// 创建时间
  createdAt DateTime @default(now())

  /// 更新时间
  updatedAt DateTime @updatedAt

  /// 关联用户
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isVerified])
  @@index([status])
  @@map("escort_profiles")
}

/// 订单表
model Order {
  /// 主键 ID
  id String @id @default(cuid()) @db.VarChar(36)

  /// 下单用户 ID
  customerId String @db.VarChar(36)

  /// 接单陪诊员 ID
  escortId String? @db.VarChar(36)

  /// 订单编号
  orderNo String @unique @db.VarChar(32)

  /// 医院名称 / 就诊地点
  hospitalName String @db.VarChar(100)

  /// 服务时间
  serviceAt DateTime

  /// 备注 / 其他诉求
  remark String? @db.Text

  /// 订单金额
  amount Decimal @db.Decimal(10, 2)

  /// 订单状态
  status OrderStatus @default(PENDING_PAYMENT)

  /// 下单用户
  customer User @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Restrict)

  /// 接单陪诊员
  escort User? @relation("EscortOrders", fields: [escortId], references: [id], onDelete: SetNull)

  /// 创建时间
  createdAt DateTime @default(now())

  /// 更新时间
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([escortId])
  @@index([status])
  @@index([serviceAt])
  @@map("orders")
}
